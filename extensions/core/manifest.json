{
    "id": "__core",
    "key": "ac30f0709756aef5aa53b92d3fcf6446",
    "name": "Core Extension",
    "version": "1.0.0",
    "description": "Core extension for Social Browser",
    "permissions": ["storage", "tabs"],
    "matches": ["<all_urls>"],
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ],
    "background": {
        "scripts": ["background.js"]
    },
    "popup": "popup.html"
}
